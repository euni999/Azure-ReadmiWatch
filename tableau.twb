      <column caption='30일내재입원율' datatype='real' name='[Calculation_4194922701848576]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [readmitted] = &apos;&lt;30&apos; THEN 1 ELSE 0 END) / COUNT([encounter_id])' />
      </column>
      <column caption='나이대별 재입원율' datatype='real' name='[Calculation_4318068034183168]' role='measure' type='quantitative'>
